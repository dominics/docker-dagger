PUID=1000
PGID=1000
TZ=Pacific/Auckland
LOCAL_IP=192.168.1.200
# Shared secret for the UsenetStreamer Stremio addon. Generate with
# `openssl rand -hex 16`. Appears in the manifest URL the TV uses
# (http://192.168.1.200:7005/<SECRET>/manifest.json) — keep it private.
USENETSTREAMER_SECRET=change-me
