PUID=1000
PGID=1000
TZ=Pacific/Auckland
LOCAL_IP=192.168.1.200

# --- AIOStreams (self-hosted Stremio aggregator; replaces the previous addon) ---
# 64-char hex encryption key. Generate: openssl rand -hex 32  (cannot change later)
AIOSTREAMS_SECRET_KEY=change-me
# Config-UI login(s): user:pass[,user2:pass2]
AIOSTREAMS_AUTH=admin:change-me
# Which of the above usernames are admins (comma-separated; blank = all are admins)
AIOSTREAMS_AUTH_ADMINS=admin
# A user:pass pair from AIOSTREAMS_AUTH used by the built-in stream proxy
AIOSTREAMS_PROXY_CREDENTIALS=admin:change-me
#
# nzbdav (usenet) credentials are NOT injected via env — configure them per-config in each
# AIOStreams instance's dashboard UI (Services → NzbDAV; enable the service and fill in):
#   url=http://nzbdav:3000 | apiKey=<nzbdav SABnzbd-section key> | WebDAV username + password
#   | AIOStreams Auth Token = <user:pass from AIOSTREAMS_AUTH>   (enables the built-in proxy)
#
# Why not env: AIOStreams v2.30.2 stores env-supplied service creds (FORCED_SERVICE_CREDENTIALS /
# DEFAULT_SERVICE_CREDENTIALS) *encrypted* and never decrypts them at resolve time — the
# ciphertext reaches `new URL()` → "Invalid URL" → usenet plays a 21KB placeholder (the purple
# "Something Went Wrong" screen). Typed-in-UI creds are encrypted once and decrypt cleanly.
# (Verified against config.ts validateOption / ensureDecrypted; no version/flag avoids it.)
#
# The home-IP usenet guarantee does NOT depend on these creds: FORCE_PROXY_* in
# docker-compose.yml (using AIOSTREAMS_PROXY_CREDENTIALS above) forces every stream through the
# built-in proxy on dagger. UI config lives in $CONFIG_DIR/aiostreams-*/db.sqlite (per instance,
# lan + ts have separate DBs), NOT in this repo — repeat the dashboard step on a fresh deploy.
# Prowlarr API key (Prowlarr → Settings → General → API Key)
PROWLARR_API_KEY=change-me

# --- Traefik DNS-01 (Route53) for internal HTTPS (aiostreams.media.varspool.com) ---
# Credentials for the least-priv IAM user traefik-acme-route53 (terraform/varspool/iam.tf).
# Traefik's letsencrypt-dns resolver uses these to obtain a Let's Encrypt cert via the
# Route53 DNS-01 challenge (the host resolves to a private IP, so HTTP-01 can't validate it).
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=us-east-1
AWS_HOSTED_ZONE_ID=Z18WAFL6G763Y0
